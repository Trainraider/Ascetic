using Gtk 4.0;
using Adw 1;
using WebKit 6.0;

Adw.Window window_main {
  default-width: 800;
  default-height: 600;
  icon-name: "template_app";
  
  content: Adw.ToolbarView {
    [top]
    Adw.HeaderBar {
      title-widget: Entry {
        hexpand: true;
        input-purpose: url;
        input-hints: no_spellcheck;
        editable: true;
        activate => $load_url_from_entry();
      };
      
      [end]
      Button open_settings_button {
        icon-name: "application-menu-symbolic";
      }
    }
    
    content: Stack stack_main {
      StackPage main_page {
        child: Overlay {
          [overlay]
          Box {
            halign: end;

            Box {
              orientation: vertical;
            }
          }

          WebKit.WebView web_view {
            hexpand: true;
            vexpand: true;
          }
        };
      }

      StackPage settings_page {
        child: $TemplateAppSettingsPage settings_page_template {};
      }
    };
  };
}